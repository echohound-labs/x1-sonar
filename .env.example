X1_RPC_URL=http://localhost:8899
DATABASE_URL=postgresql://indexer:YOUR_PASSWORD@localhost:5432/echohound
CATCHUP_DELAY_MS=100
TIP_WAIT_MS=500
CHECKPOINT_EVERY=25

# sonar-watch.js (Telegram bot)
SONAR_BOT_TOKEN=123456:YOUR_BOT_TOKEN
SONAR_ADMIN_CHAT=YOUR_ADMIN_CHAT_ID
SONAR_CHANNEL=@your_channel_or_chat_id   # optional; falls back to SONAR_ADMIN_CHAT
SONAR_POST_HOUR=15                        # optional; daily movement-baseline roll hour, UTC (default 15)
SONAR_BOARD_REFRESH_MIN=10                 # optional; pinned live-board refresh interval, minutes (default 10)
